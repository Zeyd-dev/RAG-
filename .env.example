# Copy this file to .env and fill in real values before running.

# --- Auth (shared login for internal use, no OAuth/SSO) ---
APP_USERNAME=admin
APP_PASSWORD=changeme
SESSION_SECRET=change-this-to-a-long-random-string

# --- Groq API (free tier) ---
# Get a free key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER=groq

# --- Embeddings (local, no API key needed) ---
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Google Drive import (optional) ---
# Only needed if you use the "From Drive" import button. Get a free API
# key at https://console.cloud.google.com: create/select a project,
# enable the "Google Drive API", then create an API key under
# Credentials. Only works for folders shared as "Anyone with the link
# can view".
GOOGLE_API_KEY=

# --- Storage / DB paths (defaults are fine for local use) ---
DATA_DIR=data
UPLOAD_DIR=data/uploads
CHROMA_DIR=data/chroma
DATABASE_URL=sqlite:///./data/notebook.db

# --- Optional: Supabase (Postgres+pgvector / Storage) alternate backend ---
# Leave all of these blank/unset for the default local sqlite+Chroma+disk
# setup above -- nothing below is required. Only fill these in if you want
# real persistent storage on a host with no persistent disk (e.g. a free
# Hugging Face Space). See README.md section "6b. Using Supabase for
# persistent storage" and docs/supabase_schema.sql before setting these.
# If set, DATABASE_URL above should be replaced with your Supabase
# Postgres connection string instead of the sqlite default.
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_KEY=your-service-role-key
# SUPABASE_BUCKET=documents

# --- Chunking / retrieval tuning ---
CHUNK_SIZE_TOKENS=800
CHUNK_OVERLAP_TOKENS=150
TOP_K=5

# --- Frontend origin allowed by CORS ---
FRONTEND_ORIGIN=http://localhost:5173
